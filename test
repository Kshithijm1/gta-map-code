    );
};

// ---------------------------------------------------------------------------
// Watchlist Detail (single watchlist view)
// ---------------------------------------------------------------------------

interface WatchlistDetailProps {
    watchlistId: string | null;
    selectedType: IWatchListType;
}

const WatchlistDetail: React.FC<WatchlistDetailProps> = ({
    watchlistId,
    selectedType,
}) => {
    const {
        watchlists,
        getWatchlistItems,
        addItem,
        removeItem,
        reorderItems,
        toggleFavorite,
        isLoading,
        events,
    } = useContext(WatchlistContext);

    const [isAddModalOpen, setIsAddModalOpen] = useState(false);
    const [dragIndex, setDragIndex] = useState<number | null>(null);
    const [dragOverIndex, setDragOverIndex] = useState<number | null>(null);
    const [eventFilter, setEventFilter] = useState<EventFilter>("All");

    // Check if "All Companies" is selected
    const isAllCompanies = watchlistId?.startsWith("__all_companies_") ?? false;

    const items = useMemo(() => {
        if (!watchlistId || isAllCompanies) return [];
        return getWatchlistItems(watchlistId);
    }, [watchlistId, isAllCompanies, getWatchlistItems]);

    const filteredItems = useMemo(
        () => items.filter((item) => passesEventFilter(item, eventFilter)),
        [items, eventFilter]
    );

    const watchlist = watchlists.find((w) => w.id === watchlistId);

    // ---- Add stock handler ----
    const handleAddStock = useCallback(
        async (ticker: string, companyName: string) => {
            if (!watchlistId) return;
            await addItem({
                watchlistId,
                ticker,
                companyName,
                type: selectedType,
                keyInfoDocuments: [
                    {
                        type: "10-K",
                        label: `10-K`,
                        url: `https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=${ticker}&type=10-K`,
                    },
                    {
                        type: "10-Q",
                        label: `10-Q`,
                        url: `https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=${ticker}&type=10-Q`,
                    },
                    {
                        type: "8-K",
                        label: `8-K`,
                        url: `https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=${ticker}&type=8-K`,
                    },
                ],
            });
        },
        [watchlistId, addItem, selectedType]
    );

    // ---- Remove handler ----
    const handleRemove = useCallback(
        async (itemId: string) => {
            await removeItem(itemId);
        },
        [removeItem]
    );

    // ---- Export next-week events to CSV (Outlook template) ----
    const handleExportOutlook = useCallback(() => {
        const now = new Date();
        const oneWeek = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);
        const watchlistTickers = new Set(items.map((i) => i.ticker.toUpperCase()));

        // Get next-week events for this watchlist's tickers
        const nextWeekEvents = events
            .filter((e) => {
                const d = new Date(e.event_date);
                return (
                    watchlistTickers.has(e.ticker.toUpperCase()) &&
                    d >= now &&
                    d <= oneWeek
                );
            })
            .sort((a, b) => new Date(a.event_date).getTime() - new Date(b.event_date).getTime());

        // Also include items with nextEarnings in the next week
        const itemsNextWeek = items.filter((item) => {
            if (!item.nextEarnings) return false;
            const d = new Date(item.nextEarnings);
            return d >= now && d <= oneWeek;
        });

        // Build CSV rows
        const csvRows = [
            ["Ticker", "Company Name", "Event", "Date"].join(","),
        ];

        // Add events from the events API
        nextWeekEvents.forEach((e) => {
            csvRows.push(
                [e.ticker, `"${e.company_name}"`, `"${e.event_name}"`, e.event_date].join(",")
            );
        });

        // Add items with nextEarnings that aren't already in events
        const eventTickers = new Set(nextWeekEvents.map((e) => e.ticker.toUpperCase()));
        itemsNextWeek
            .filter((item) => !eventTickers.has(item.ticker.toUpperCase()))
            .forEach((item) => {
                csvRows.push(
                    [item.ticker, `"${item.companyName}"`, "Earnings", item.nextEarnings || ""].join(",")
                );
            });

        if (csvRows.length <= 1) {
            alert("No events scheduled for the next week for this watchlist.");
            return;
        }

        // Download CSV
        const blob = new Blob([csvRows.join("\n")], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `watchlist_next_week_${watchlist?.name?.replace(/\s+/g, "_") || "export"}.csv`;
        link.click();
        URL.revokeObjectURL(url);
    }, [items, events, watchlist]);

    // ---- Drag and Drop ----
    const onDragStart = (
        e: React.DragEvent<HTMLTableRowElement>,
        index: number
    ) => {
        setDragIndex(index);
        e.dataTransfer.effectAllowed = "move";
        if (e.currentTarget) {
            e.currentTarget.style.opacity = "0.4";
        }
    };

    const onDragEnter = (
        _e: React.DragEvent<HTMLTableRowElement>,
        index: number
    ) => {
        setDragOverIndex(index);
    };

    const onDragEnd = (e: React.DragEvent<HTMLTableRowElement>) => {
        if (e.currentTarget) {
            e.currentTarget.style.opacity = "1";
        }

        if (
            dragIndex !== null &&
            dragOverIndex !== null &&
            dragIndex !== dragOverIndex &&
            watchlistId
        ) {
            const reordered = [...filteredItems];
            const [dragged] = reordered.splice(dragIndex, 1);
            reordered.splice(dragOverIndex, 0, dragged);
            reorderItems(
                watchlistId,
                reordered.map((i) => i.id)
            );
        }

        setDragIndex(null);
        setDragOverIndex(null);
    };

    const onDragOver = (e: React.DragEvent<HTMLTableRowElement>) => {
        e.preventDefault();
    };

    // ---- Route: All Companies ----
    if (isAllCompanies) {
        return <AllCompaniesView selectedType={selectedType} />;
    }

    // ---- Empty state ----
    if (!watchlistId || !watchlist) {
        return (
            <Box
                display="flex"
                justifyContent="center"
                alignItems="center"
                height="100%"
                color="text.secondary"
            >
                <Typography variant="h6">Select a watchlist to view details</Typography>
            </Box>
        );
    }

    return (
        <Box sx={{ height: "100%", display: "flex", flexDirection: "column", p: 3 }}>
            {/* Header */}
            <Box
                display="flex"
                justifyContent="space-between"
                alignItems="flex-start"
                mb={1}
            >
                <Box>
                    <Box display="flex" alignItems="center" gap={1} mb={0.5}>
                        <Typography variant="h5" fontWeight="bold">
                            {watchlist.name}
                        </Typography>
                        <IconButton
                            size="small"
                            onClick={() => toggleFavorite(watchlist.id)}
                            sx={{ color: watchlist.favorite ? "#3B5BDB" : "#bdbdbd" }}
                        >
                            {watchlist.favorite ? (
                                <StarIcon fontSize="small" />
                            ) : (
                                <StarBorderIcon fontSize="small" />
                            )}
                        </IconButton>
                        <Chip
                            icon={
                                watchlist.type === "user" ? (
                                    <PersonOutlineIcon fontSize="small" />
                                ) : (
                                    <GroupIcon fontSize="small" />
                                )
                            }
                            label={watchlist.type === "user" ? "User" : "Team"}
                            size="small"
                            variant="outlined"
                            sx={{ ml: 1 }}
                        />
                        <Chip
                            label={`${items.length} stock${items.length !== 1 ? "s" : ""}`}
                            size="small"
                            sx={{ ml: 1, bgcolor: "#f0f0f0" }}
                        />
                    </Box>
                    <Typography variant="body2" color="text.secondary">
                        {watchlist.description}
                    </Typography>
                </Box>
                <Stack direction="row" spacing={1}>
                    <Button
                        variant="outlined"
                        startIcon={<FileDownloadOutlinedIcon />}
                        onClick={handleExportOutlook}
                        disabled={isLoading}
                        sx={{
                            textTransform: "none",
                            borderRadius: 2,
                            fontWeight: 600,
                            px: 2,
                            borderColor: "#3B5BDB",
                            color: "#3B5BDB",
                            "&:hover": { bgcolor: "rgba(59, 91, 219, 0.06)" },
                        }}
                    >
                        Export Next Week
                    </Button>
                    <Button
                        variant="contained"
                        startIcon={isLoading ? <CircularProgress size={16} color="inherit" /> : <AddIcon />}
                        onClick={() => setIsAddModalOpen(true)}
                        disabled={isLoading}
                        sx={{
                            textTransform: "none",
                            borderRadius: 2,
                            background: TABLE_HEADER_BG,
                            fontWeight: 600,
                            px: 2.5,
                            boxShadow: "0 2px 8px rgba(59, 91, 219, 0.25)",
                            "&:hover": {
                                background: "linear-gradient(135deg, #162d4d 0%, #2f4fc0 50%, #4a6be0 100%)",
                            },
                        }}
                    >
                        Add Stock
                    </Button>
                </Stack>
            </Box>

            {/* Filter bar — below description */}
            <EventFilterBar activeFilter={eventFilter} onChange={setEventFilter} />

            <Divider sx={{ mb: 2 }} />

            {/* Drag instruction */}
            {filteredItems.length > 1 && (
                <Typography
                    variant="caption"
                    color="text.secondary"
                    sx={{ mb: 1, display: "block" }}
                >
                    💡 Drag rows to reorder priority. #1 = highest priority.
                </Typography>
            )}

            {/* Table */}
            <TableContainer
                component={Paper}
                sx={{
                    flex: 1,
                    width: "100%",
                    boxShadow: "0 2px 12px rgba(0,0,0,0.06)",
                    borderRadius: 2.5,
                    overflow: "auto",
                    border: "1px solid rgba(0,0,0,0.06)",
                }}
            >
                <Table stickyHeader size="small">
                    <TableHead>
                        <TableRow>
                            <TableCell width={40} sx={TABLE_HEADER_CELL_SX}></TableCell>
                            <TableCell width={60} sx={TABLE_HEADER_CELL_SX}>
                                Priority
                            </TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Ticker</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Company Name</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Next Earnings</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Previous Earnings</TableCell>
                            <TableCell sx={{ ...TABLE_HEADER_CELL_SX, minWidth: 120 }}>
                                Key Info
                            </TableCell>
                            <TableCell width={50} sx={TABLE_HEADER_CELL_SX}></TableCell>
                        </TableRow>
                    </TableHead>
                    <TableBody>
                        {filteredItems.length === 0 ? (
                            <TableRow>
                                <TableCell colSpan={8} align="center" sx={{ py: 8 }}>
                                    <Box>
                                        <Typography
                                            variant="body1"
                                            color="text.secondary"
                                            gutterBottom
                                        >
                                            {eventFilter !== "All"
                                                ? `No stocks with earnings in "${eventFilter}" filter.`
                                                : "No stocks in this watchlist yet."}
                                        </Typography>
                                        {eventFilter === "All" && (
                                            <Button
                                                variant="outlined"
                                                size="small"
                                                startIcon={<AddIcon />}
                                                onClick={() => setIsAddModalOpen(true)}
                                                sx={{ textTransform: "none", mt: 1 }}
                                            >
                                                Add your first stock
                                            </Button>
                                        )}
                                    </Box>
                                </TableCell>
                            </TableRow>
                        ) : (
                            filteredItems.map((item, index) => {
                                const isDropTarget =
                                    dragOverIndex === index && dragIndex !== index;

                                return (
                                    <TableRow
                                        key={item.id}
                                        draggable
                                        onDragStart={(e) => onDragStart(e, index)}
                                        onDragEnter={(e) => onDragEnter(e, index)}
                                        onDragEnd={onDragEnd}
                                        onDragOver={onDragOver}
                                        sx={{
                                            cursor: "grab",
                                            "&:hover": {
                                                backgroundColor: "rgba(59, 91, 219, 0.04)",
                                            },
                                            backgroundColor: isDropTarget
                                                ? "rgba(59, 91, 219, 0.08)"
                                                : index % 2 === 1
                                                    ? "rgba(0,0,0,0.015)"
                                                    : "white",
                                            borderTop: isDropTarget
                                                ? "2px solid #3B5BDB"
                                                : "none",
                                            transition:
                                                "background-color 0.15s ease, border 0.15s ease",
                                            "&:active": { cursor: "grabbing" },
                                        }}
                                    >
                                        <TableCell sx={{ py: 1.5 }}>
                                            <IconButton
                                                size="small"
                                                disableRipple
                                                sx={{
                                                    cursor: "grab",
                                                    "&:active": { cursor: "grabbing" },
                                                }}
                                            >
                                                <DragIndicatorIcon
                                                    fontSize="small"
                                                    color="disabled"
                                                />
                                            </IconButton>
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <Chip
                                                label={`#${item.rank}`}
                                                size="small"
                                                sx={{
                                                    fontWeight: 700,
                                                    fontSize: "12px",
                                                    bgcolor:
                                                        item.rank <= 3
                                                            ? "rgba(59, 91, 219, 0.1)"
                                                            : "#f5f5f5",
                                                    color:
                                                        item.rank <= 3
                                                            ? "#3B5BDB"
                                                            : "#666",
                                                    minWidth: 36,
                                                }}
                                            />
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <Typography fontWeight="bold" fontSize="14px">
                                                {item.ticker}
                                            </Typography>
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <Typography fontSize="13px" color="text.secondary">
                                                {item.companyName}
                                            </Typography>
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <EarningsCell date={item.nextEarnings} isNext />
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <EarningsCell date={item.previousEarnings} />
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            {item.keyInfoDocuments &&
                                                item.keyInfoDocuments.length > 0 ? (
                                                <KeyInfoDropdown
                                                    docs={item.keyInfoDocuments}
                                                />
                                            ) : (
                                                <Typography
                                                    variant="caption"
                                                    color="text.disabled"
                                                >
                                                    —
                                                </Typography>
                                            )}
                                        </TableCell>
                                        <TableCell sx={{ py: 1.5 }}>
                                            <Tooltip title="Remove from watchlist">
                                                <IconButton
                                                    size="small"
                                                    onClick={() => handleRemove(item.id)}
                                                    sx={{
                                                        color: "#bbb",
                                                        "&:hover": {
                                                            color: "#d32f2f",
                                                            bgcolor: "#ffebee",
                                                        },
                                                    }}
                                                >
                                                    <CloseIcon fontSize="small" />
                                                </IconButton>
                                            </Tooltip>
                                        </TableCell>
                                    </TableRow>
                                );
                            })
                        )}
                    </TableBody>
                </Table>
            </TableContainer>

            <AddStockModal
                open={isAddModalOpen}
                onClose={() => setIsAddModalOpen(false)}
                onAdd={handleAddStock}
                existingTickers={items.map((i) => i.ticker)}
            />
        </Box>
    );
};

export default WatchlistDetail;
