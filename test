                                                    if (folderClickTimerRef.current) clearTimeout(folderClickTimerRef.current);
                                                    const clickEvent = { shiftKey: e.shiftKey, ctrlKey: e.ctrlKey, metaKey: e.metaKey } as React.MouseEvent;
                                                    const itemIdx = startIndex + idx;
                                                    folderClickTimerRef.current = setTimeout(() => {
                                                        handleItemClick(clickEvent, id, itemIdx);
                                                        folderClickTimerRef.current = null;
                                                    }, 250);
                                                } else {
                                                    handleItemClick(e, id, startIndex + idx);
