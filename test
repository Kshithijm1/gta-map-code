import logger from "@/lib/logger";
import { BigQuery } from "@google-cloud/bigquery";
import { NextRequest, NextResponse } from "next/server";
import { SECRET_PROJECT_ID, SECRET_WATCHLIST_DATASET } from "@/lib/env";

const DATASET = SECRET_WATCHLIST_DATASET || "cbldt-b016-int-2e05.raw_ext_sgam_1832_aiq_interactive_ist";

/**
 * Handles multiple update operations on watchlist items:
 *  - action: "remove"      — soft-delete item (is_active = 'N')
 *  - action: "reorder"     — update item_rank for given items
 *  - action: "deleteWatchlist" — soft-delete entire watchlist + its items
 *  - action: "editWatchlist"   — update watchlist name/description
 */
export async function POST(req: NextRequest) {
    logger.info("Updating watchlist item(s)");
    try {
        const body = await req.json();
        const { action, user_sid } = body;

        if (!user_sid || !action) {
            return NextResponse.json(
                { error: "user_sid and action are required" },
                { status: 400 }
            );
        }

        const bigQueryClient = new BigQuery({ projectId: SECRET_PROJECT_ID });

        switch (action) {
            // ── Remove a single item (soft delete) ──
            case "remove": {
                const { watchlist_item_id } = body;
                if (!watchlist_item_id) {
                    return NextResponse.json(
                        { error: "watchlist_item_id is required for remove" },
                        { status: 400 }
                    );
                }

                await bigQueryClient.query({
                    query: `
                        UPDATE \`${DATASET}.watchlists_items\`
                        SET is_active = 'N',
                            last_updated_user_sid = @user_sid,
                            _updated_ts = CURRENT_TIMESTAMP()
                        WHERE watchlist_item_id = @watchlist_item_id
                    `,
                    params: {
                        user_sid,
                        watchlist_item_id: Number(watchlist_item_id),
                    },
                });

                return NextResponse.json(
                    { success: true, message: "Item removed" },
                    { status: 200 }
                );
            }

            // ── Reorder items ──
            case "reorder": {
                const { items } = body; // Array of { watchlist_item_id, item_rank }
                if (!items || !Array.isArray(items)) {
                    return NextResponse.json(
                        { error: "items array is required for reorder" },
                        { status: 400 }
                    );
                }

                // Execute updates sequentially (BigQuery doesn't support batch DML easily)
                for (const item of items) {
                    await bigQueryClient.query({
                        query: `
                            UPDATE \`${DATASET}.watchlists_items\`
                            SET item_rank = @item_rank,
                                last_updated_user_sid = @user_sid,
                                _updated_ts = CURRENT_TIMESTAMP()
                            WHERE watchlist_item_id = @watchlist_item_id
                        `,
                        params: {
                            user_sid,
                            watchlist_item_id: Number(item.watchlist_item_id),
                            item_rank: Number(item.item_rank),
                        },
                    });
                }

                return NextResponse.json(
                    { success: true, message: "Items reordered" },
                    { status: 200 }
                );
            }

            // ── Delete entire watchlist (soft delete) ──
            case "deleteWatchlist": {
                const { watchlist_id } = body;
                if (!watchlist_id) {
                    return NextResponse.json(
                        { error: "watchlist_id is required for deleteWatchlist" },
                        { status: 400 }
                    );
                }

                // Soft-delete the watchlist itself
                await bigQueryClient.query({
                    query: `
                        UPDATE \`${DATASET}.watchlists\`
                        SET is_active = 'N',
                            last_updated_user_sid = @user_sid,
                            _updated_ts = CURRENT_TIMESTAMP()
                        WHERE watchlist_id = @watchlist_id
                    `,
                    params: {
                        user_sid,
                        watchlist_id: Number(watchlist_id),
                    },
                });

                // Soft-delete all items in that watchlist
                await bigQueryClient.query({
                    query: `
                        UPDATE \`${DATASET}.watchlists_items\`
                        SET is_active = 'N',
                            last_updated_user_sid = @user_sid,
                            _updated_ts = CURRENT_TIMESTAMP()
                        WHERE watchlist_id = @watchlist_id
                    `,
                    params: {
                        user_sid,
                        watchlist_id: Number(watchlist_id),
                    },
                });

                return NextResponse.json(
                    { success: true, message: "Watchlist deleted" },
                    { status: 200 }
                );
            }

            // ── Edit watchlist name/description ──
            case "editWatchlist": {
                const { watchlist_id, watchlist_name, watchlist_description } = body;
                if (!watchlist_id) {
                    return NextResponse.json(
                        { error: "watchlist_id is required for editWatchlist" },
                        { status: 400 }
                    );
                }

                await bigQueryClient.query({
                    query: `
                        UPDATE \`${DATASET}.watchlists\`
                        SET watchlist_name = @watchlist_name,
                            watchlist_description = @watchlist_description,
                            last_updated_user_sid = @user_sid,
                            _updated_ts = CURRENT_TIMESTAMP()
                        WHERE watchlist_id = @watchlist_id
                    `,
                    params: {
                        user_sid,
                        watchlist_id: Number(watchlist_id),
                        watchlist_name: watchlist_name || "",
                        watchlist_description: watchlist_description || "",
                    },
                });

                return NextResponse.json(
                    { success: true, message: "Watchlist updated" },
                    { status: 200 }
                );
            }

            default:
                return NextResponse.json(
                    { error: `Unknown action: ${action}` },
                    { status: 400 }
                );
        }
    } catch (error: any) {
        logger.error("Error updating watchlist", error);
        return NextResponse.json(
            { error: error.message || "Failed to update" },
            { status: 500 }
        );
    }
}




