/* ============================================
   Row-Based Folder Structure Table Styles
   ============================================ */

/* Container */
.tableContainer {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow-x: auto;
  overflow-y: auto;
}

/* ---- Header Row ---- */
.headerRow {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  border-bottom: 2px solid #e0e0e0;
  background-color: #fafafa;
  font-weight: 600;
  font-size: 13px;
  color: #616161;
  user-select: none;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 2;
}

/* ---- Table Body ---- */
.tableBody {
  flex: 1;
}

/* ---- Table Row ---- */
.tableRow {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.15s ease;
  min-height: 44px;
  user-select: none;
}

.tableRow:hover {
  background-color: rgba(25, 118, 210, 0.04);
}

.tableRow.selected {
  background-color: rgba(25, 118, 210, 0.10);
}

.tableRow.selected:hover {
  background-color: rgba(25, 118, 210, 0.15);
}

/* ============================================
   Column Cells — ALL fixed widths for alignment
   ============================================ */

.cellCheckbox {
  flex: 0 0 36px;
  width: 36px;
  min-width: 36px;
  max-width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellIcon {
  flex: 0 0 32px;
  width: 32px;
  min-width: 32px;
  max-width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellName {
  flex: 0 0 220px;
  width: 220px;
  min-width: 220px;
  max-width: 220px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-right: 12px;
  overflow: hidden;
}

.nameText {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 14px;
  color: #212121;
}

.cellSharing {
  flex: 0 0 50px;
  width: 50px;
  min-width: 50px;
  max-width: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellFavorite {
  flex: 0 0 36px;
  width: 36px;
  min-width: 36px;
  max-width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellSize {
  flex: 0 0 70px;
  width: 70px;
  min-width: 70px;
  max-width: 70px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
}

.cellType {
  flex: 0 0 50px;
  width: 50px;
  min-width: 50px;
  max-width: 50px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
}

/* Tags — scrollable horizontally */
.cellTags {
  flex: 0 0 150px;
  width: 150px;
  min-width: 150px;
  max-width: 150px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.cellTags::-webkit-scrollbar {
  display: none;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  background-color: #f0f4f8;
  color: #334155;
  border: 1px solid #e2e8f0;
  white-space: nowrap;
  transition: all 0.2s ease;
}

/* Date — scrollable horizontally */
.cellDate {
  flex: 0 0 160px;
  width: 160px;
  min-width: 160px;
  max-width: 160px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  display: flex;
  align-items: center;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.cellDate::-webkit-scrollbar {
  display: none;
}

.cellOwner {
  flex: 0 0 100px;
  width: 100px;
  min-width: 100px;
  max-width: 100px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
}

.cellDelete {
  flex: 0 0 36px;
  width: 36px;
  min-width: 36px;
  max-width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #757575;
  cursor: pointer;
}

.cellDelete:hover {
  color: #d32f2f;
}

.cellSpacer {
  flex: 1;
  min-width: 0;
}

/* ---- Icons ---- */
.folderIcon {
  color: #ffc107;
  font-size: 24px !important;
}

.fileIcon {
  font-size: 22px !important;
}

.pdfIcon {
  color: #f44336;
}

.csvIcon {
  color: #4caf50;
}

.imgIcon {
  color: #9c27b0;
}

.txtIcon {
  color: #607d8b;
}

.docIcon {
  color: #2196f3;
}

/* Favorite Star */
.favoriteIcon {
  cursor: pointer;
  font-size: 20px !important;
  transition: color 0.15s ease, transform 0.15s ease;
}

.favoriteIcon:hover {
  transform: scale(1.15);
}

.favoriteActive {
  color: #ffc107 !important;
}

.favoriteInactive {
  color: #bdbdbd !important;
}

.favoriteInactive:hover {
  color: #ffc107 !important;
}

/* Sharing icons */
.sharingIcon {
  font-size: 20px !important;
  color: #9e9e9e;
}

.personalIcon {
  color: #1976d2;
}

.teamIcon {
  color: #2e7d32;
}

/* Header column text */
.headerCell {
  display: flex;
  align-items: center;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #9e9e9e;
}

/* Empty state */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #9e9e9e;
}
