                    try {
                        // Bug 13 Fix: Gather file paths for the move/copy payload.
                        // For folders, ONLY send the folder path (ending with "/").
                        // The backend move API handles recursive folder moves natively.
                        // Sending individual child file paths alongside a folder path
                        // causes them to be moved twice (once by the folder move, once individually),
                        // resulting in duplicates and "Some files failed to move" errors.
                        let payloadIds: string[] = [];
                        for (const item of moveCopyState.items) {
                            if ("fileCount" in item) {
                                // It's a folder — only send the folder's own path
                                let folderPath = (item as IFolder).path || item.id;
                                if (!folderPath.endsWith("/")) folderPath += "/";
                                // Strip gs:// prefix if present — backend works with relative paths
                                if (folderPath.startsWith("gs://")) {
                                    const parts = folderPath.replace("gs://", "").split("/");
                                    parts.shift(); // remove bucket name
                                    folderPath = parts.join("/");
                                }
                                payloadIds.push(folderPath);
                            } else {
                                payloadIds.push((item as IFolderFile).filePath || item.id);
                            }
                        }
