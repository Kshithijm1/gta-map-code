/* ============================================
   Row-Based Folder Structure Table Styles
   ============================================ */

/* Container */
.tableContainer {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow-x: auto;
  overflow-y: auto;
  /* Both scrolls on container ensures header & body align */
}

/* ---- Header Row ---- */
.headerRow {
  display: grid;
  align-items: center;
  padding: 8px 12px;
  border-bottom: 2px solid #e0e0e0;
  background-color: #fafafa;
  font-weight: 600;
  font-size: 13px;
  color: #616161;
  user-select: none;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 2;
  min-width: 1050px;
  /* guarantees columns don't squish */
}

/* ---- Table Body ---- */
.tableBody {
  flex: 1;
  /* overflow handled by parent */
}

/* ---- Table Row ---- */
.tableRow {
  display: grid;
  align-items: center;
  padding: 6px 12px;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.15s ease;
  min-height: 44px;
  user-select: none;
  min-width: 1050px;
}

.tableRow:hover {
  background-color: rgba(25, 118, 210, 0.04);
}

.tableRow.selected {
  background-color: rgba(25, 118, 210, 0.10);
}

.tableRow.selected:hover {
  background-color: rgba(25, 118, 210, 0.15);
}

/* Grid Layouts depending on isRootView (hidden columns) */
.standardGrid {
  /* Checkbox(36) Icon(32) Name(1fr) Sharing(60) Fav(40) Size(75) Type(55) Tags(200) Date(120) Owner(120) Del(40) */
  grid-template-columns: 36px 32px minmax(160px, 1fr) 60px 40px 75px 60px 200px 120px 120px 40px;
}

.rootGrid {
  /* No Checkbox, Fav, or Type */
  /* Icon(32) Name(1fr) Sharing(60) Size(75) Tags(200) Date(120) Owner(120) Del(40) */
  grid-template-columns: 32px minmax(160px, 1fr) 60px 75px 200px 120px 120px 40px;
}

/* ---- Column Cells ---- */
/* Bulletproof Alignment: Fixed widths for all except Name */

.cellCheckbox {
  flex: 0 0 36px;
  width: 36px;
  min-width: 36px;
  max-width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellIcon {
  flex: 0 0 32px;
  width: 32px;
  min-width: 32px;
  max-width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Name takes all remaining space. Must have min-width: 0 to allow truncating */
.cellName {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-right: 16px;
  overflow: hidden;
}

.nameText {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 14px;
  color: #212121;
}

.cellSharing {
  flex: 0 0 60px;
  width: 60px;
  min-width: 60px;
  max-width: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellFavorite {
  flex: 0 0 40px;
  width: 40px;
  min-width: 40px;
  max-width: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cellSize {
  flex: 0 0 75px;
  width: 75px;
  min-width: 75px;
  max-width: 75px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 16px;
  display: flex;
  align-items: center;
}

.cellType {
  flex: 0 0 55px;
  width: 55px;
  min-width: 55px;
  max-width: 55px;
  /* Reduced width per user request */
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 16px;
  display: flex;
  align-items: center;
}

.cellTags {
  flex: 0 0 200px;
  width: 200px;
  min-width: 200px;
  max-width: 200px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  padding-right: 16px;
  -ms-overflow-style: none;
  scrollbar-width: thin;
  /* Show scrollbar as requested */
}

.cellTags::-webkit-scrollbar {
  height: 4px;
}

.cellTags::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 4px;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  background-color: #f0f4f8;
  color: #334155;
  border: 1px solid #e2e8f0;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.cellDate {
  flex: 0 0 120px;
  width: 120px;
  min-width: 120px;
  max-width: 120px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow-x: auto;
  /* Scrollable per user request */
  overflow-y: hidden;
  text-overflow: clip;
  /* Clip instead of ellipsis so they can scroll */
  padding-right: 16px;
  display: flex;
  align-items: center;
  scrollbar-width: thin;
}

.cellDate::-webkit-scrollbar {
  height: 4px;
}

.cellDate::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 4px;
}

.cellOwner {
  flex: 0 0 120px;
  width: 120px;
  min-width: 120px;
  max-width: 120px;
  font-size: 13px;
  color: #757575;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 16px;
  display: flex;
  align-items: center;
}

.cellDelete {
  flex: 0 0 40px;
  width: 40px;
  min-width: 40px;
  max-width: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #757575;
  cursor: pointer;
}

.cellDelete:hover {
  color: #d32f2f;
}

.cellSpacer {
  flex: 1;
  min-width: 0;
}

/* ---- Icons ---- */
.folderIcon {
  color: #ffc107;
  font-size: 24px !important;
}

.fileIcon {
  font-size: 22px !important;
}

/* Specific File Type Colors */
.pdfIcon {
  color: #f44336;
}

.csvIcon {
  color: #4caf50;
}

.imgIcon {
  color: #9c27b0;
}

.txtIcon {
  color: #607d8b;
}

.docIcon {
  color: #2196f3;
}

/* Favorite Star */
.favoriteIcon {
  cursor: pointer;
  font-size: 20px !important;
  transition: color 0.15s ease, transform 0.15s ease;
}

.favoriteIcon:hover {
  transform: scale(1.15);
}

.favoriteActive {
  color: #ffc107 !important;
}

.favoriteInactive {
  color: #bdbdbd !important;
}

.favoriteInactive:hover {
  color: #ffc107 !important;
}

/* Sharing icons */
.sharingIcon {
  font-size: 20px !important;
  color: #9e9e9e;
}

.personalIcon {
  color: #1976d2;
}

.teamIcon {
  color: #2e7d32;
}

/* Header column text */
.headerCell {
  display: flex;
  align-items: center;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #9e9e9e;
}

/* Empty state */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #9e9e9e;
}
