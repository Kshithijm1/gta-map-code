"use client";
import { useContext, useMemo } from "react";
import { WatchlistContext } from "@/context/WatchlistContext";
import { IWatchlistItem, IWatchListType, IWatchlistEvent } from "@/interface";

/**
 * Convenience hook that wraps the WatchlistContext and provides
 * derived helpers for a specific watchlist.
 */
export const useWatchlist = (activeWatchlistId?: string | null) => {
    const ctx = useContext(WatchlistContext);

    const activeItems: IWatchlistItem[] = useMemo(() => {
        if (!activeWatchlistId) return [];
        return ctx.getWatchlistItems(activeWatchlistId);
    }, [activeWatchlistId, ctx]);

    const filteredWatchlists = useMemo(
        () => ({
            user: ctx.watchlists.filter((w) => w.type === "user"),
            team: ctx.watchlists.filter((w) => w.type === "team"),
        }),
        [ctx.watchlists]
    );

    const isDuplicateTicker = (watchlistId: string, ticker: string): boolean => {
        return ctx.items.some(
            (i) =>
                i.watchlistId === watchlistId &&
                i.ticker.toUpperCase() === ticker.toUpperCase()
        );
    };

    // Events for the active watchlist's tickers
    const activeEvents: IWatchlistEvent[] = useMemo(() => {
        if (!activeWatchlistId) return [];
        const activeTickers = new Set(
            activeItems.map((i) => i.ticker.toUpperCase())
        );
        return ctx.events.filter((e) =>
            activeTickers.has(e.ticker.toUpperCase())
        );
    }, [activeWatchlistId, activeItems, ctx.events]);

    // Upcoming events (next 7 days)
    const upcomingEvents: IWatchlistEvent[] = useMemo(() => {
        const now = new Date();
        const oneWeek = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);
        return activeEvents.filter((e) => {
            const eventDate = new Date(e.event_date);
            return eventDate >= now && eventDate <= oneWeek;
        });
    }, [activeEvents]);

    return {
        ...ctx,
        activeItems,
        filteredWatchlists,
        isDuplicateTicker,
        activeEvents,
        upcomingEvents,
    };
};







