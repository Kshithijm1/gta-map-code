import React, { useState } from 'react';
import {
    Dialog,
    DialogContent,
    DialogActions,
    Button,
    List,
    ListItemButton,
    ListItemIcon,
    ListItemText,
    Typography,
    Box,
    Collapse,
} from '@mui/material';
import FolderOpenIcon from '@mui/icons-material/FolderOpen';
import DriveFileMoveIcon from '@mui/icons-material/DriveFileMove';
import ContentCopyIcon from '@mui/icons-material/ContentCopy';
import ExpandMoreIcon from '@mui/icons-material/ExpandMore';
import ChevronRightIcon from '@mui/icons-material/ChevronRight';
import HomeIcon from '@mui/icons-material/Home';
import { IFolder } from '../../interfaces/folderInterfaces';

interface MoveCopyDialogProps {
    open: boolean;
    mode: 'move' | 'copy';
    personalFolders: IFolder[];
    teamFolders: IFolder[];
    currentFolderId: string | null;
    onClose: () => void;
    onSubmit: (destinationFolderId: string, destinationPath: string) => Promise<void>;
    isProcessing: boolean;
    activeTeams: string[];
    userSID: string;
    movingItemIds?: string[];
}

/* ── Types ──────────────────────────────────────────── */

type NodeRender = {
    id: string;
    name: string;
    path: string;
    depth: number;
    isRoot: boolean;
    isCurrent: boolean;
};

interface TreeNode {
    node: NodeRender;
    children: TreeNode[];
}

/* ── Helpers ────────────────────────────────────────── */

const getDisplayName = (name: string) => {
    const clean = name.replace(/\/$/, '');
    const parts = clean.split('/');
    return parts[parts.length - 1];
};

/**
 * Convert the flat renderNodes list (with depth) into a proper tree.
 * Relies on the nodes being in parent-before-child order.
 */
const buildTreeFromFlat = (nodes: NodeRender[]): TreeNode[] => {
    const roots: TreeNode[] = [];
    const stack: TreeNode[] = [];

    for (const n of nodes) {
        const treeNode: TreeNode = { node: n, children: [] };

        // Pop the stack until the top is a valid parent (depth < current)
        while (stack.length > 0 && stack[stack.length - 1].node.depth >= n.depth) {
            stack.pop();
        }

        if (stack.length === 0) {
            roots.push(treeNode);
        } else {
            stack[stack.length - 1].children.push(treeNode);
        }
        stack.push(treeNode);
    }

    return roots;
};

/* ── Recursive tree item ────────────────────────────── */

const FolderTreeItem: React.FC<{
    treeNode: TreeNode;
    selectedId: string | null;
    onSelect: (id: string, isCurrent: boolean) => void;
    depth: number;
}> = ({ treeNode, selectedId, onSelect, depth }) => {
    const [expanded, setExpanded] = useState(true);
    const { node } = treeNode;
    const hasChildren = treeNode.children.length > 0;
    const isSelected = selectedId === node.id;
    const isDisabled = node.isCurrent;

    return (
        <>
            <ListItemButton
                disabled={isDisabled}
                selected={isSelected}
                onClick={() => onSelect(node.id, node.isCurrent)}
                sx={{
                    pl: 2 + depth * 2.5,
                    py: 1,
                    borderRadius: '10px',
                    mx: 0.75,
                    mb: 0.5,
                    transition: 'all 0.15s ease',
                    '&.Mui-selected': {
                        backgroundColor: 'rgba(25, 118, 210, 0.08)',
                        border: '1px solid rgba(25, 118, 210, 0.3)',
                    },
                    '&.Mui-selected:hover': {
                        backgroundColor: 'rgba(25, 118, 210, 0.14)',
                    },
                    '&:hover': {
                        backgroundColor: 'rgba(0, 0, 0, 0.03)',
                    },
                    '&.Mui-disabled': {
                        opacity: 0.45,
                    },
                }}
            >
                {/* Expand / collapse chevron */}
                {hasChildren ? (
                    <ListItemIcon
                        sx={{ minWidth: 28, cursor: 'pointer' }}
                        onClick={(e: React.MouseEvent) => {
                            e.stopPropagation();
                            setExpanded(!expanded);
                        }}
                    >
                        {expanded ? (
                            <ExpandMoreIcon fontSize="small" sx={{ color: '#666' }} />
                        ) : (
                            <ChevronRightIcon fontSize="small" sx={{ color: '#666' }} />
                        )}
                    </ListItemIcon>
                ) : (
                    <ListItemIcon sx={{ minWidth: 28 }}>
                        <Box sx={{ width: 20 }} />
                    </ListItemIcon>
                )}

                {/* Folder icon badge */}
                <ListItemIcon sx={{ minWidth: 36 }}>
                    <Box
                        sx={{
                            width: 30,
                            height: 30,
                            borderRadius: '8px',
                            backgroundColor: isSelected
                                ? 'rgba(25, 118, 210, 0.12)'
                                : node.isRoot
                                    ? 'rgba(66, 165, 245, 0.12)'
                                    : 'rgba(255, 167, 38, 0.12)',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center',
                        }}
                    >
                        {node.isRoot ? (
                            <HomeIcon
                                sx={{
                                    fontSize: 18,
                                    color: isSelected ? '#1976d2' : '#42a5f5',
                                }}
                            />
                        ) : (
                            <FolderOpenIcon
                                sx={{
                                    fontSize: 18,
                                    color: isSelected ? '#1976d2' : '#ffa726',
                                }}
                            />
                        )}
                    </Box>
                </ListItemIcon>

                <ListItemText
                    primary={getDisplayName(node.name)}
                    primaryTypographyProps={{
                        fontSize: '0.875rem',
                        fontWeight: isSelected ? 600 : 400,
                        color: isSelected ? '#1976d2' : 'inherit',
                    }}
                />
            </ListItemButton>

            {hasChildren && (
                <Collapse in={expanded}>
                    {treeNode.children.map((child) => (
                        <FolderTreeItem
                            key={child.node.id}
                            treeNode={child}
                            selectedId={selectedId}
                            onSelect={onSelect}
                            depth={depth + 1}
                        />
                    ))}
                </Collapse>
            )}
        </>
    );
};

/* ── Main dialog ────────────────────────────────────── */

export const MoveCopyDialog: React.FC<MoveCopyDialogProps> = ({
    open,
    mode,
    personalFolders,
    teamFolders,
    currentFolderId,
    onClose,
    onSubmit,
    isProcessing,
    activeTeams,
    userSID,
    movingItemIds = [],
}) => {
    const [selectedDestinationId, setSelectedDestinationId] = useState<string | null>(null);

    /* ─────────────────────────────────────────────────────
     * DATA LOGIC — identical to the original MoveCopyDialog
     * ───────────────────────────────────────────────────── */

    const sortFolders = (list: IFolder[]) => [...list]
        .filter(f => !f.isSystemFolder)
        .sort((a, b) => {
            if (a.depth !== b.depth) return (a.depth || 0) - (b.depth || 0);
            return a.name.localeCompare(b.name);
        });

    const sortedPersonal = sortFolders(personalFolders);
    const sortedTeam = sortFolders(teamFolders);

    const renderNodes: NodeRender[] = [];

    const isCurrentTeam = currentFolderId?.startsWith('team_') || teamFolders.some(f => f.id === currentFolderId);

    // Identify paths of folders being moved so we don't allow moving them into themselves or their children
    const skipPrefixes: string[] = [];
    for (const mId of movingItemIds) {
        const item = [...personalFolders, ...teamFolders].find(f => f.id === mId);
        if (item) skipPrefixes.push(item.path);
    }
    const shouldSkip = (path: string) => skipPrefixes.some(p => path.startsWith(p));

    // Personal root
    if (!currentFolderId || !isCurrentTeam) {
        renderNodes.push({
            id: 'personal',
            name: 'Personal Root',
            path: `${userSID}/`,
            depth: 0,
            isRoot: true,
            isCurrent: currentFolderId === 'personal' && mode === 'move'
        });

        // Personal subfolders
        for (const f of sortedPersonal) {
            if (shouldSkip(f.path)) continue;

            renderNodes.push({
                id: f.id,
                name: f.name,
                path: f.path,
                depth: f.depth || 1,
                isRoot: false,
                isCurrent: f.id === currentFolderId && mode === 'move'
            });
        }
    }

    // Team roots and subfolders
    if (!currentFolderId || isCurrentTeam) {
        for (const tc of activeTeams) {
            renderNodes.push({
                id: `team_${tc}`,
                name: tc,
                path: `${tc}/`,
                depth: 0,
                isRoot: true,
                isCurrent: currentFolderId === `team_${tc}` && mode === 'move'
            });

            // Team subfolders specifically for this teamCode
            for (const f of sortedTeam.filter(tf => tf.teamCode === tc)) {
                if (shouldSkip(f.path)) continue;

                renderNodes.push({
                    id: f.id,
                    name: f.name,
                    path: f.path,
                    depth: f.depth || 1,
                    isRoot: false,
                    isCurrent: f.id === currentFolderId && mode === 'move'
                });
            }
        }
    }

    /* ─────────────────────────────────────────────────────
     * Convert flat nodes → tree for the new UI
     * ───────────────────────────────────────────────────── */
    const tree = buildTreeFromFlat(renderNodes);

    const handleSelect = (id: string, isCurrent: boolean) => {
        if (!isCurrent) {
            setSelectedDestinationId(id);
        }
    };

    // Original handleConfirm logic — unchanged
    const handleConfirm = () => {
        if (!selectedDestinationId) return;

        const destNode = renderNodes.find(r => r.id === selectedDestinationId);
        if (!destNode) return;

        let destPath = destNode.path.endsWith("/") ? destNode.path : `${destNode.path}/`;
        if (destPath.startsWith("gs://")) {
            const parts = destPath.replace("gs://", "").split("/");
            parts.shift();
            destPath = parts.join("/");
        }

        onSubmit(selectedDestinationId, destPath);
    };

    /* ─────────────────────────────────────────────────────
     * RENDERING — ShareToTeamDialog style
     * ───────────────────────────────────────────────────── */

    const isMove = mode === 'move';
    const HeaderIcon = isMove ? DriveFileMoveIcon : ContentCopyIcon;

    return (
        <Dialog
            open={open}
            onClose={onClose}
            maxWidth="xs"
            fullWidth
            PaperProps={{
                sx: {
                    borderRadius: '16px',
                    minHeight: 380,
                    overflow: 'hidden',
                },
            }}
        >
            {/* Header with icon */}
            <Box sx={{ px: 3, pt: 2.5, pb: 1, display: 'flex', alignItems: 'center', gap: 1.5 }}>
                <Box
                    sx={{
                        width: 40,
                        height: 40,
                        borderRadius: '12px',
                        background: isMove
                            ? 'linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%)'
                            : 'linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%)',
                        display: 'flex',
                        alignItems: 'center',
                        justifyContent: 'center',
                        flexShrink: 0,
                    }}
                >
                    <HeaderIcon sx={{ fontSize: 22, color: isMove ? '#1976d2' : '#388e3c' }} />
                </Box>
                <Typography
                    variant="h6"
                    sx={{ fontWeight: 600, fontSize: '1.1rem', lineHeight: 1.3, m: 0 }}
                >
                    {isMove ? 'Move to' : 'Copy to'}
                </Typography>
            </Box>

            <DialogContent sx={{ pt: 0 }}>
                <Typography variant="body2" color="text.secondary" sx={{ mb: 2.5 }}>
                    Choose a destination folder:
                </Typography>
                <Box
                    sx={{
                        border: '1px solid #e0e0e0',
                        borderRadius: '12px',
                        height: 360,
                        overflow: 'auto',
                        py: 0.75,
                        backgroundColor: '#fafafa',
                    }}
                >
                    <List dense disablePadding>
                        {tree.length === 0 ? (
                            <Box sx={{ p: 3, textAlign: 'center' }}>
                                <FolderOpenIcon sx={{ fontSize: 40, color: '#bdbdbd', mb: 1 }} />
                                <Typography variant="body2" color="text.secondary">
                                    No folders available.
                                </Typography>
                            </Box>
                        ) : (
                            tree.map((tn) => (
                                <FolderTreeItem
                                    key={tn.node.id}
                                    treeNode={tn}
                                    selectedId={selectedDestinationId}
                                    onSelect={handleSelect}
                                    depth={0}
                                />
                            ))
                        )}
                    </List>
                </Box>
            </DialogContent>

            <DialogActions sx={{ px: 3, pb: 2.5, justifyContent: 'flex-end' }}>
                <Button
                    onClick={onClose}
                    disabled={isProcessing}
                    sx={{
                        borderRadius: '8px',
                        textTransform: 'none',
                        color: '#666',
                    }}
                >
                    Cancel
                </Button>
                <Button
                    onClick={handleConfirm}
                    variant="contained"
                    disabled={!selectedDestinationId || selectedDestinationId === currentFolderId || isProcessing}
                    sx={{
                        borderRadius: '8px',
                        textTransform: 'none',
                        px: 3,
                        background: isMove
                            ? 'linear-gradient(135deg, #1976d2 0%, #1565c0 100%)'
                            : 'linear-gradient(135deg, #388e3c 0%, #2e7d32 100%)',
                        '&:hover': {
                            background: isMove
                                ? 'linear-gradient(135deg, #1565c0 0%, #0d47a1 100%)'
                                : 'linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%)',
                        },
                    }}
                >
                    {isProcessing
                        ? isMove ? 'Moving…' : 'Copying…'
                        : isMove ? 'Move here' : 'Copy here'}
                </Button>
            </DialogActions>
        </Dialog>
    );
};
