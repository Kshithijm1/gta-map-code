import logger from "@/lib/logger";
import { BigQuery } from "@google-cloud/bigquery";
import { NextRequest, NextResponse } from "next/server";
import { SECRET_PROJECT_ID, SECRET_WATCHLIST_DATASET } from "@/lib/env";

const DATASET = SECRET_WATCHLIST_DATASET || "cbldt-b016-int-2e05.raw_ext_sgam_1832_aiq_interactive_ist";

export async function POST(req: NextRequest) {
    logger.info("Fetching watchlist events via table function");
    try {
        const { user_sid, team_code } = await req.json();

        if (!user_sid) {
            return NextResponse.json(
                { error: "user_sid is required" },
                { status: 400 }
            );
        }

        const bigQueryClient = new BigQuery({ projectId: SECRET_PROJECT_ID });

        // BigQuery requires each part of the path to be individually backticked if they contain hyphens
        const tablePath = DATASET.split('.').map(p => `\`${p}\``).join('.') + `.\`tf_get_watchlists_events\``;

        // Call the table function for events (S&P events data feed)
        const query = `
            SELECT *
            FROM ${tablePath}(@user_sid, @team_code)
        `;

        const [rows] = await bigQueryClient.query({
            query,
            params: { user_sid, team_code: team_code || "" },
        });

        // Map rows to IWatchlistEvent shape
        const events = (rows || []).map((row: any) => ({
            ticker: row.ticker || "",
            company_name: row.company_name || "",
            event_name: row.event_name || "",
            event_date: row.event_date || "",
            event_time: row.event_time || undefined,
            event_type: row.event_type || undefined,
        }));

        return NextResponse.json({ events }, { status: 200 });
    } catch (error: any) {
        logger.error("Error fetching watchlist events", error);
        return NextResponse.json(
            { error: error.message || "Failed to fetch watchlist events" },
            { status: 500 }
        );
    }
}
