  const handleGcsFileSelection = async (
    newSelectionModel: GridRowSelectionModel,
    resolvedFiles?: any[]
  ) => {
    onCustomSelectionChange(newSelectionModel);

    const selectedDocs: any[] = [];
    if (resolvedFiles) {
      resolvedFiles.forEach((file) => {
        if (!newSelectionModel.includes(file.id)) return;
        const existing = customSourceDocuments.find((d) => d.id === file.id);
        if (existing) {
          selectedDocs.push(existing);
        } else {
          // Fix for Bug 11: Create a synthetic IGCSFile for Team Files so they get processed
          // Use file.contentType from GCS metadata (not guessed from extension)
          selectedDocs.push({
            id: String(file.id),
            filePath: String(file.filePath || file.id),
            name: String(file.name),
            size: Number(file.size || 0),
            contentType: file.contentType || "application/octet-stream",
            tokenCount: "0",
            updated: new Date(),
          });
        }
      });
    } else {
      const docs = customSourceDocuments.filter((doc) =>
        newSelectionModel.includes(doc.id)
      );
      selectedDocs.push(...docs);
    }

    let totalTokenCount = 0;

    for (const doc of selectedDocs) {
      let tokenCount = parseInt(doc.tokenCount);
