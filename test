// ─── Helpers ─────────────────────────────────────────────
const FAVORITES_KEY_PREFIX = "folder_favorites_";

const getFavoritesKey = (sID: string) => `${FAVORITES_KEY_PREFIX}${sID}`;

const loadFavorites = (sID: string): Set<string> => {
    try {
        const raw = localStorage.getItem(getFavoritesKey(sID));
        if (raw) return new Set(JSON.parse(raw));
    } catch { /* ignore */ }
    return new Set();
};

const saveFavorites = (sID: string, favorites: Set<string>) => {
    localStorage.setItem(getFavoritesKey(sID), JSON.stringify([...favorites]));
};

// Folder colors persistence
const FOLDER_COLORS_KEY_PREFIX = "folder_colors_";
const getFolderColorsKey = (sID: string) => `${FOLDER_COLORS_KEY_PREFIX}${sID}`;

const loadFolderColors = (sID: string): Record<string, string> => {
    try {
        const raw = localStorage.getItem(getFolderColorsKey(sID));
        if (raw) return JSON.parse(raw);
    } catch { /* ignore */ }
    return {};
};

const saveFolderColors = (sID: string, colors: Record<string, string>) => {
    localStorage.setItem(getFolderColorsKey(sID), JSON.stringify(colors));
};

