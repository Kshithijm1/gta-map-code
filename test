import React, { useState } from "react";
import {
    Dialog,
    DialogTitle,
    DialogContent,
    DialogActions,
    Button,
    Box,
    Typography,
    Alert,
} from "@mui/material";
import { ITickerOptions } from "@/interface";
import { useTickerOptions } from "@/hooks/useTickerOptions";
import { TickerAutocomplete } from "../TickerAutocomplete";

interface AddStockModalProps {
    open: boolean;
    onClose: () => void;
    onAdd: (ticker: string, companyName: string, idBbCompany?: string) => void;
    existingTickers?: string[];
}

const AddStockModal: React.FC<AddStockModalProps> = ({
    open,
    onClose,
    onAdd,
    existingTickers = [],
}) => {
    const [selectedTicker, setSelectedTicker] = useState<ITickerOptions | null>(null);
    const [error, setError] = useState("");
    const { tickerLoadingMessage, tickerOptions, fetchOptions } = useTickerOptions();

    const isDuplicate =
        selectedTicker !== null &&
        existingTickers.some(
            (t) => t.toUpperCase() === selectedTicker.code.trim().toUpperCase()
        );

    const handleSubmit = () => {
        if (!selectedTicker) {
            setError("Please select a ticker from the dropdown.");
            return;
        }

        if (isDuplicate) {
            setError(`${selectedTicker.code} is already in this watchlist.`);
            return;
        }

        onAdd(selectedTicker.code.trim().toUpperCase(), selectedTicker.name, selectedTicker.company_id);
        setSelectedTicker(null);
        setError("");
        onClose();
    };

    const handleClose = () => {
        setSelectedTicker(null);
        setError("");
        onClose();
    };

    return (
        <Dialog
            open={open}
            onClose={handleClose}
            maxWidth="sm"
            fullWidth
            PaperProps={{
                sx: { borderRadius: 2 },
            }}
        >
            <DialogTitle sx={{ fontWeight: 600 }}>
                Add Stock to Watchlist
            </DialogTitle>
            <DialogContent>
                <Typography variant="body2" color="text.secondary" sx={{ mb: 2 }}>
                    Search for a ticker and select it from the dropdown. The stock
                    will be added at the bottom of your watchlist.
                </Typography>

                {error && (
                    <Alert severity="error" sx={{ mb: 2 }} onClose={() => setError("")}>
                        {error}
                    </Alert>
                )}

                <Box display="flex" flexDirection="column" gap={2} mt={1}>
                    <TickerAutocomplete
                        options={tickerOptions}
                        sx={{ width: "100%" }}
                        fetchOptions={fetchOptions}
                        value={selectedTicker}
                        tickerLoadingMessage={tickerLoadingMessage}
                        showHelperText={isDuplicate}
                        helperText={isDuplicate ? `${selectedTicker?.code} already exists in this watchlist` : ""}
                        handleFilterUpdate={(_event, newValue, _reason) => {
                            setSelectedTicker(newValue);
                            setError("");
                        }}
                    />

                    {selectedTicker && !isDuplicate && (
                        <Box sx={{ p: 1.5, bgcolor: 'action.hover', borderRadius: 1 }}>
                            <Typography variant="body2" color="text.secondary">
                                Company
                            </Typography>
                            <Typography variant="body1" fontWeight={500}>
                                {selectedTicker.name}
                            </Typography>
                            {selectedTicker.sector && (
                                <>
                                    <Typography variant="body2" color="text.secondary" sx={{ mt: 0.5 }}>
                                        Sector
                                    </Typography>
                                    <Typography variant="body2">
                                        {selectedTicker.sector}
                                    </Typography>
                                </>
                            )}
                            {selectedTicker.industry && (
                                <>
                                    <Typography variant="body2" color="text.secondary" sx={{ mt: 0.5 }}>
                                        Industry
                                    </Typography>
                                    <Typography variant="body2">
                                        {selectedTicker.industry}
                                    </Typography>
                                </>
                            )}
                        </Box>
                    )}
                </Box>
            </DialogContent>
            <DialogActions sx={{ px: 3, pb: 2 }}>
                <Button onClick={handleClose} sx={{ textTransform: "none" }}>
                    Cancel
                </Button>
                <Button
                    onClick={handleSubmit}
                    variant="contained"
                    disabled={!selectedTicker || isDuplicate}
                    sx={{ textTransform: "none" }}
                >
                    Add Stock
                </Button>
            </DialogActions>
        </Dialog>
    );
};

export default AddStockModal;
