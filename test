import logger from "@/lib/logger";
import { BigQuery } from "@google-cloud/bigquery";
import { NextRequest, NextResponse } from "next/server";
import { SECRET_PROJECT_ID, SECRET_WATCHLIST_DATASET } from "@/lib/env";

const DATASET = SECRET_WATCHLIST_DATASET || "cbldt-b016-int-2e05.raw_ext_sgam_1832_aiq_interactive_ist";

export async function POST(req: NextRequest) {
    logger.info("Fetching watchlists for user");
    try {
        const { user_sid, team_code } = await req.json();

        if (!user_sid) {
            return NextResponse.json(
                { error: "user_sid is required" },
                { status: 400 }
            );
        }

        const bigQueryClient = new BigQuery({ projectId: SECRET_PROJECT_ID });

        // BigQuery requires each part of the path to be individually backticked if they contain hyphens
        const tablePath = DATASET.split('.').map(p => `\`${p}\``).join('.') + `.\`watchlists\``;

        const query = `
            SELECT
                watchlist_id,
                user_sid,
                admin_group,
                team_code,
                access_group,
                watchlist_name,
                watchlist_description,
                watchlist_access_level,
                is_active,
                last_updated_user_sid,
                _created_ts,
                _updated_ts
            FROM ${tablePath}
            WHERE (user_sid = @user_sid OR team_code = @team_code)
              AND is_active = 'Y'
            ORDER BY _created_ts ASC
        `;

        const [rows] = await bigQueryClient.query({
            query,
            params: { user_sid, team_code: team_code || "" },
        });

        // Map BigQuery rows to the frontend IWatchLists shape
        const watchlists = (rows || []).map((row: any) => ({
            id: String(row.watchlist_id),
            watchlist_id: row.watchlist_id,
            name: row.watchlist_name || "",
            description: row.watchlist_description || "",
            favorite: false, // Client-side only — stored in localStorage
            type: row.watchlist_access_level === "team" ? "team" : "user",
            user_sid: row.user_sid,
            team_code: row.team_code,
            access_group: row.access_group,
            admin_group: row.admin_group,
            watchlist_access_level: row.watchlist_access_level,
            is_active: row.is_active,
            last_updated_user_sid: row.last_updated_user_sid,
            _created_ts: row._created_ts,
            _updated_ts: row._updated_ts,
        }));

        return NextResponse.json({ watchlists }, { status: 200 });
    } catch (error: any) {
        logger.error("Error fetching watchlists", error);
        return NextResponse.json(
            { error: error.message || "Failed to fetch watchlists" },
            { status: 500 }
        );
    }
}
