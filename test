import logger from "@/lib/logger";
import { BigQuery } from "@google-cloud/bigquery";
import { NextRequest, NextResponse } from "next/server";
import { SECRET_PROJECT_ID, SECRET_WATCHLIST_DATASET } from "@/lib/env";

const DATASET = SECRET_WATCHLIST_DATASET || "cbldt-b016-int-2e05.raw_ext_sgam_1832_aiq_interactive_ist";

export async function POST(req: NextRequest) {
    logger.info("Creating a new watchlist");
    try {
        const {
            user_sid,
            team_code,
            access_group,
            admin_group,
            watchlist_name,
            watchlist_description,
            watchlist_access_level,
        } = await req.json();

        if (!user_sid || !watchlist_name) {
            return NextResponse.json(
                { error: "user_sid and watchlist_name are required" },
                { status: 400 }
            );
        }

        const bigQueryClient = new BigQuery({ projectId: SECRET_PROJECT_ID });

        // BigQuery requires each part of the path to be individually backticked if they contain hyphens
        const tablePath = DATASET.split('.').map(p => `\`${p}\``).join('.') + `.\`watchlists\``;

        const query = `
            INSERT INTO ${tablePath} (
                user_sid,
                admin_group,
                team_code,
                access_group,
                watchlist_name,
                watchlist_description,
                watchlist_access_level,
                is_active,
                last_updated_user_sid,
                _created_ts,
                _updated_ts
            ) VALUES (
                @user_sid,
                @admin_group,
                @team_code,
                @access_group,
                @watchlist_name,
                @watchlist_description,
                @watchlist_access_level,
                'Y',
                @user_sid,
                CURRENT_TIMESTAMP(),
                CURRENT_TIMESTAMP()
            )
        `;

        await bigQueryClient.query({
            query,
            params: {
                user_sid,
                admin_group: admin_group || "",
                team_code: team_code || "",
                access_group: access_group || "",
                watchlist_name,
                watchlist_description: watchlist_description || "",
                watchlist_access_level: watchlist_access_level || "user",
            },
        });

        return NextResponse.json(
            { success: true, message: "Watchlist created successfully" },
            { status: 200 }
        );
    } catch (error: any) {
        logger.error("Error creating watchlist", error);
        return NextResponse.json(
            { error: error.message || "Failed to create watchlist" },
            { status: 500 }
        );
    }
}
