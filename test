    const getWatchlistName = (watchlistId: string) => {
        return watchlists.find((w) => w.id === watchlistId)?.name ?? "—";
    };

    const typeLabel = selectedType === "user" ? "User" : "Team";

    return (
        <Box sx={{ height: "100%", display: "flex", flexDirection: "column", p: 3 }}>
            {/* Header */}
            <Box display="flex" alignItems="center" gap={1} mb={0.5}>
                <Typography variant="h5" fontWeight="bold">
                    All Companies
                </Typography>
                <Chip
                    icon={
                        selectedType === "user" ? (
                            <PersonOutlineIcon sx={{ fontSize: 14 }} />
                        ) : (
                            <GroupIcon sx={{ fontSize: 14 }} />
                        )
                    }
                    label={typeLabel}
                    size="small"
                    variant="outlined"
                    sx={{ ml: 1, height: 24 }}
                />
            </Box>
            <Typography variant="body2" color="text.secondary" mb={1.5}>
                View all companies across all {typeLabel.toLowerCase()} watchlists
            </Typography>

            {/* Filter bar */}
            <EventFilterBar activeFilter={eventFilter} onChange={setEventFilter} />

            <Typography variant="subtitle2" color="text.secondary" mb={1}>
                Watchlist Details&nbsp;&nbsp;
                <Typography component="span" fontWeight={600} color="text.primary">
                    {filteredItems.length} companies
                </Typography>
            </Typography>

            {/* Table */}
            <TableContainer
                component={Paper}
                sx={{
                    flex: 1,
                    boxShadow: "0 2px 12px rgba(0,0,0,0.06)",
                    borderRadius: 2.5,
                    overflow: "auto",
                    border: "1px solid rgba(0,0,0,0.06)",
                }}
            >
                <Table stickyHeader size="small">
                    <TableHead>
                        <TableRow>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Company Name</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Ticker</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Watchlist</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Next Earnings</TableCell>
                            <TableCell sx={TABLE_HEADER_CELL_SX}>Previous Earnings</TableCell>
                        </TableRow>
                    </TableHead>
                    <TableBody>
                        {filteredItems.length === 0 ? (
                            <TableRow>
                                <TableCell colSpan={5} align="center" sx={{ py: 8 }}>
                                    <Typography color="text.secondary">
                                        {eventFilter !== "All"
                                            ? `No companies with earnings in "${eventFilter}" filter.`
                                            : `No companies in any ${typeLabel.toLowerCase()} watchlist yet.`}
                                    </Typography>
                                </TableCell>
                            </TableRow>
                        ) : (
                            filteredItems.map((item, idx) => (
                                <TableRow
                                    key={item.id}
                                    sx={{
                                        transition: "background-color 0.15s ease",
                                        "&:hover": { bgcolor: "rgba(59, 91, 219, 0.04)" },
                                        bgcolor: idx % 2 === 1 ? "rgba(0,0,0,0.015)" : "white",
                                    }}
                                >
                                    <TableCell sx={{ py: 1.5, fontSize: "13px" }}>
                                        {item.companyName}
                                    </TableCell>
                                    <TableCell
