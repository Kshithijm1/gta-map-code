import React, { useContext, useState, useCallback, useMemo } from "react";
import {
    Box,
    Typography,
    Divider,
    Chip,
    Paper,
    Button,
    Table,
    TableBody,
    TableCell,
    TableContainer,
    TableHead,
    TableRow,
    IconButton,
    Tooltip,
    Stack,
    Select,
    MenuItem,
    FormControl,
} from "@mui/material";
import { IWatchlistItem, IKeyInfoDocument, IWatchListType, IWatchlistEvent } from "@/interface";
import FileDownloadOutlinedIcon from "@mui/icons-material/FileDownloadOutlined";
import CircularProgress from "@mui/material/CircularProgress";
import PersonOutlineIcon from "@mui/icons-material/PersonOutline";
import GroupIcon from "@mui/icons-material/Group";
import StarIcon from "@mui/icons-material/Star";
import StarBorderIcon from "@mui/icons-material/StarBorder";
import AddIcon from "@mui/icons-material/Add";
import DragIndicatorIcon from "@mui/icons-material/DragIndicator";
import CloseIcon from "@mui/icons-material/Close";
import DescriptionOutlinedIcon from "@mui/icons-material/DescriptionOutlined";
import CalendarTodayIcon from "@mui/icons-material/CalendarToday";
import AddStockModal from "./AddStockModal";
import { WatchlistContext } from "@/context/WatchlistContext";
import dayjs from "dayjs";

// ---------------------------------------------------------------------------
// Shared styles
// ---------------------------------------------------------------------------
const TABLE_HEADER_BG = "linear-gradient(135deg, #1e3a5f 0%, #3B5BDB 50%, #5C7CFA 100%)";
const TABLE_HEADER_CELL_SX = {
    background: TABLE_HEADER_BG,
    color: "#fff",
    fontWeight: 700,
    fontSize: "12px",
    letterSpacing: "0.04em",
    textTransform: "uppercase" as const,
    borderBottom: "none",
    py: 1.4,
};

// ---------------------------------------------------------------------------
// Date helpers
// ---------------------------------------------------------------------------
const formatEarningsDate = (dateStr?: string) => {
    if (!dateStr) return "—";
    const d = dayjs(dateStr);
    if (!d.isValid()) return "—";
    return d.format("MMM D, YYYY");
};

const isUpcoming = (dateStr?: string) => {
    if (!dateStr) return false;
    return dayjs(dateStr).isAfter(dayjs());
};

// ---------------------------------------------------------------------------
// Event filter types and helpers
// ---------------------------------------------------------------------------
type EventFilter =
    | "All"
    | "This Year"
    | "This Month"
    | "This Week"
    | "Today"
    | "Next Month"
    | "Next Week"
    | "Next Day";

const EVENT_FILTERS: EventFilter[] = [
    "All",
    "This Year",
    "This Month",
    "This Week",
    "Today",
    "Next Month",
    "Next Week",
    "Next Day",
];

const passesEventFilter = (item: IWatchlistItem, filter: EventFilter): boolean => {
    if (filter === "All") return true;
    const next = item.nextEarnings ? dayjs(item.nextEarnings) : null;
    if (!next || !next.isValid()) return false;

    const now = dayjs();

    switch (filter) {
        case "Today":
            return next.isSame(now, "day");
        case "This Week":
            return next.isSame(now, "week");
        case "This Month":
            return next.isSame(now, "month");
        case "This Year":
            return next.isSame(now, "year");
        case "Next Day":
            return next.isAfter(now) && next.isBefore(now.add(1, "day").endOf("day"));
        case "Next Week":
            return next.isAfter(now) && next.isBefore(now.add(1, "week").endOf("day"));
        case "Next Month":
            return next.isAfter(now) && next.isBefore(now.add(1, "month").endOf("day"));
        default:
            return true;
    }
};

// ---------------------------------------------------------------------------
// Earnings date cell
// ---------------------------------------------------------------------------
const EarningsCell: React.FC<{ date?: string; isNext?: boolean }> = ({ date, isNext }) => {
    const formatted = formatEarningsDate(date);
    const upcoming = isNext && isUpcoming(date);

    return (
        <Box display="flex" alignItems="center" gap={0.75}>
            <CalendarTodayIcon
                sx={{
                    fontSize: 14,
                    color: upcoming ? "#3B5BDB" : "#999",
                }}
            />
            <Typography
                fontSize="13px"
                fontWeight={upcoming ? 600 : 400}
                sx={{ color: upcoming ? "#1e3a5f" : "#555" }}
            >
                {formatted}
            </Typography>
            {upcoming && (
                <Chip
                    label="Upcoming"
                    size="small"
                    sx={{
                        height: 20,
                        fontSize: "10px",
                        fontWeight: 700,
                        bgcolor: "rgba(59, 91, 219, 0.1)",
                        color: "#3B5BDB",
                        border: "1px solid rgba(59, 91, 219, 0.25)",
                    }}
                />
            )}
        </Box>
    );
};

// ---------------------------------------------------------------------------
// Filter chip bar
// ---------------------------------------------------------------------------
const EventFilterBar: React.FC<{
    activeFilter: EventFilter;
    onChange: (f: EventFilter) => void;
}> = ({ activeFilter, onChange }) => (
    <Stack direction="row" spacing={0.75} sx={{ flexWrap: "wrap", rowGap: 0.75, mb: 2 }}>
        {EVENT_FILTERS.map((f) => {
            const isActive = activeFilter === f;
            return (
                <Chip
                    key={f}
                    label={f}
                    size="small"
                    onClick={() => onChange(f)}
                    sx={{
                        fontWeight: isActive ? 700 : 500,
                        fontSize: "12px",
                        height: 28,
                        px: 0.5,
                        cursor: "pointer",
                        bgcolor: isActive ? "#3B5BDB" : "rgba(0,0,0,0.04)",
                        color: isActive ? "#fff" : "#555",
                        border: isActive ? "none" : "1px solid rgba(0,0,0,0.08)",
                        transition: "all 0.2s ease",
                        "&:hover": {
                            bgcolor: isActive ? "#2f4fc0" : "rgba(59, 91, 219, 0.08)",
                            color: isActive ? "#fff" : "#3B5BDB",
                        },
                    }}
                />
            );
        })}
    </Stack>
);

// ---------------------------------------------------------------------------
// Key Info Dropdown Select
// ---------------------------------------------------------------------------
const KEY_INFO_TYPES = ["10-K", "10-Q", "8-K"];

const KeyInfoDropdown: React.FC<{ docs: IKeyInfoDocument[] }> = ({ docs }) => {
    const [selectedType, setSelectedType] = useState<string>("");

    const handleChange = (value: string) => {
        setSelectedType(value);
        const doc = docs.find((d) => d.type === value);
        if (doc) {
            window.open(doc.url, "_blank", "noopener,noreferrer");
        }
    };

    return (
        <FormControl size="small" sx={{ minWidth: 100 }}>
            <Select
                value={selectedType}
                displayEmpty
                onChange={(e) => handleChange(e.target.value)}
                sx={{
                    fontSize: "12px",
                    height: 30,
                    borderRadius: 1,
                    "& .MuiSelect-select": {
                        py: 0.5,
                        display: "flex",
                        alignItems: "center",
                    },
                }}
                renderValue={(value) => {
                    if (!value) {
                        return (
                            <Box display="flex" alignItems="center" gap={0.5}>
                                <DescriptionOutlinedIcon sx={{ fontSize: 14, color: "#888" }} />
                                <Typography variant="caption" color="text.secondary">
                                    Key Info
                                </Typography>
                            </Box>
                        );
                    }
                    return value;
                }}
            >
                {KEY_INFO_TYPES.map((type) => {
                    const doc = docs.find((d) => d.type === type);
                    const colorMap: Record<string, string> = {
                        "10-K": "#1565c0",
                        "10-Q": "#2e7d32",
                        "8-K": "#e65100",
                    };
                    return (
                        <MenuItem
                            key={type}
                            value={type}
                            disabled={!doc}
                            sx={{ fontSize: "13px", py: 1 }}
                        >
                            <Box display="flex" alignItems="center" gap={1}>
                                <DescriptionOutlinedIcon
                                    sx={{
                                        fontSize: 16,
                                        color: doc ? colorMap[type] : "#ccc",
                                    }}
                                />
                                <Typography fontSize="13px" color={doc ? "inherit" : "text.disabled"}>
                                    {type}
                                </Typography>
                                {doc?.date && (
                                    <Typography variant="caption" color="text.secondary" ml={1}>
                                        ({doc.date})
                                    </Typography>
                                )}
                            </Box>
                        </MenuItem>
                    );
                })}
            </Select>
        </FormControl>
    );
};

// ---------------------------------------------------------------------------
// All Companies View
// ---------------------------------------------------------------------------
interface AllCompaniesViewProps {
    selectedType: IWatchListType;
}

const AllCompaniesView: React.FC<AllCompaniesViewProps> = ({ selectedType }) => {
    const { getAllItemsForType, watchlists } = useContext(WatchlistContext);
    const [eventFilter, setEventFilter] = useState<EventFilter>("All");

    const allItems = useMemo(() => getAllItemsForType(selectedType), [
        getAllItemsForType,
        selectedType,
    ]);

    // de-duplicate by ticker for the "All Companies" view
    const uniqueItems = useMemo(() => {
        const seen = new Set<string>();
        return allItems.filter((item) => {
            const key = item.ticker.toUpperCase();
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
