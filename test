
  const addCustomTag = (rowId: number, label: string) => {
    setPendingFiles((prevFiles) => {
      const updatedFiles = [...prevFiles];
      const fileToUpdate = updatedFiles[rowId];
      if (fileToUpdate) {
        const existingCustomTags = (fileToUpdate.metadata.customTags as ICustomTag[]) || [];
        const alreadyExists = existingCustomTags.some(
          (t) => t.label.toLowerCase() === label.toLowerCase()
        );
        if (!alreadyExists) {
          updatedFiles[rowId] = {
            ...fileToUpdate,
            metadata: {
              ...fileToUpdate.metadata,
              customTags: [...existingCustomTags, { rowId, label }],
            },
          };
        }
      }
      return updatedFiles;
    });
  };

  const handleRemoveCustomTag = (tag: ICustomTag) => {
    setPendingFiles((prevFiles) => {
      const updatedFiles = [...prevFiles];
      const fileToUpdate = updatedFiles[tag.rowId];
      if (fileToUpdate) {
        const updatedCustomTags = (fileToUpdate.metadata.customTags as ICustomTag[]).filter(
          (t) => !(t.label === tag.label && t.rowId === tag.rowId)
        );
        updatedFiles[tag.rowId] = {
          ...fileToUpdate,
          metadata: {
            ...fileToUpdate.metadata,
            customTags: updatedCustomTags,
          },
        };
      }
      return updatedFiles;
    });
  };
