import React, { useState, useContext, useMemo, useEffect, useRef } from "react";

import { IGCSFile } from "@/interface";
import { GridRowSelectionModel } from "@mui/x-data-grid";
import {
    Box,
    Button,
    Dialog,
    DialogActions,
    DialogContent,
    DialogContentText,
    DialogTitle,
    Typography,
    Grid2 as Grid,
} from "@mui/material";
import DeleteIcon from "@mui/icons-material/Delete";
import ArrowBack from "@mui/icons-material/ArrowBack";
import ReactMarkdown from "react-markdown";
import { MarkdownRenderer } from "../MarkdownRenderer";
import { UserContext } from "@/context/UserContext";
import { useNotification } from "@/context/NotificationContext";
import logger from "@/lib/logger";
import { FolderStructure } from "../FolderStructure";
import { IFolderFile, IFolder } from "@/interfaces/folderInterfaces";

interface ICustomDocumentRenderer {
    rows: IGCSFile[];
    documentsLoading: boolean;
    getCustomSourceDocuments: () => Promise<void>;
    handleGcsFileSelection: (newSelectionModel: GridRowSelectionModel, resolvedFiles?: IFolderFile[]) => void;
    gcsSelectionModel: GridRowSelectionModel | undefined;
    removeCustomDocuments: (ids: string[]) => void;
    isOpen?: boolean;
    triggerNavigateToPersonal?: boolean;
    onNavigateComplete?: () => void;
}

const CustomDocumentRenderer: React.FC<ICustomDocumentRenderer> = (props) => {
    const {
        rows,
        handleGcsFileSelection,
        gcsSelectionModel,
        getCustomSourceDocuments,
        removeCustomDocuments,
        documentsLoading,
        isOpen,
        triggerNavigateToPersonal,
        onNavigateComplete,
    } = props;

    const { user } = useContext(UserContext);
    const { showNotification } = useNotification();

    // Document Read Mode state
    const [readMode, setReadMode] = useState(false);
    const [reviewDocumentItem, setReviewDocumentItem] = useState<IFolderFile | null>(null);
    const [documentContent, setDocumentContent] = useState<string>("");
    const [loadingDocument, setLoadingDocument] = useState(false);


    // Selected items (files + folders)
    const [, setSelectedFolderItems] = useState<(IFolder | IFolderFile)[]>([]);
    // Persist selected IDs across remounts (fix #4)
    const [persistedSelectedIds, setPersistedSelectedIds] = useState<string[]>([]);
    // Reset persisted selection when modal closes (Bug 7/8 related)
    useEffect(() => {
        if (!isOpen) {
            setPersistedSelectedIds([]);
        }
    }, [isOpen]);

    // Map GCS files to IFolderFile format for FolderStructure
    const mappedFiles: IFolderFile[] = useMemo(() => rows.map((row) => {
        let folderId = "personal";
        if (row.filePath) {
            const parts = row.filePath.split("/");
            if (parts.length > 5) {
                parts.pop();
                folderId = parts.join("/") + "/";
            }
        }
        return {
            id: row.id || row.filePath,
            name: row.name,
            size: typeof row.size === 'string' ? parseInt(row.size, 10) : row.size,
            filePath: row.filePath,
            contentType: row.contentType,
            updated: row.updated ? new Date(row.updated) : new Date(),
            tokenCount: row.tokenCount || "0",
            folderType: "personal" as const,
            folderId,
            ownerSID: user?.sID || "",
            createdAt: row.uploadedAt ? new Date(row.uploadedAt) : (row.createdAt ? new Date(row.createdAt) : (row.updated ? new Date(row.updated) : new Date())),
            uploadedAt: row.uploadedAt,
            tags: row.tags || [],
        };
    }), [rows, user?.sID]);

    // Action handlers for context menu
    const handleRename = async (item: IFolder | IFolderFile, newName: string) => {
        if (!user?.sID) return;

        try {
            let oldPath = item.id;
            // Clean up the gs:// prefix for the API call 
            if (oldPath.startsWith("gs://")) {
                // The GCS bucket is included in the gs:// uri, we need everything after the bucket
                const pathParts = oldPath.replace("gs://", "").split("/");
                pathParts.shift(); // remove bucket name
                oldPath = pathParts.join("/");
            }

            const isFolder = 'fileCount' in item;
            const parts = oldPath.split("/").filter(Boolean);
            if (parts.length > 0) {
                parts[parts.length - 1] = newName;
            }
            let newPath = parts.join("/");
            if (isFolder) newPath += "/";

            const response = await fetch("/api/uploadDocuments/rename", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    oldFilePath: oldPath,
                    newFilePath: newPath
                }),
            });
            const data = await response.json();

            if (data.success) {
                showNotification(`Renamed to "${newName}"`, { severity: "success" });
                await getCustomSourceDocuments(); // Refresh the list
            } else {
                showNotification(data.message || "Failed to rename", { severity: "error" });
            }
        } catch (error: any) {
            logger.error(`Error renaming: ${error?.message || error}`);
            showNotification(`Error renaming: ${error?.message || "Internal network error"}`, { severity: "error" });
        }
    };

    const handleDownload = async (itemOrItems: IFolder | IFolderFile | (IFolder | IFolderFile)[], isPreview: boolean = false) => {
        if (!user?.sID) return;

        try {
            const itemsToDownload = Array.isArray(itemOrItems) ? itemOrItems : [itemOrItems];
            if (itemsToDownload.length === 0) return;

            const isBulk = itemsToDownload.length > 1;
            const displayName = isBulk ? `${itemsToDownload.length} items` : itemsToDownload[0].name;

            showNotification(isPreview ? `Opening "${displayName}"...` : `Preparing download for "${displayName}"...`, { severity: "info" });

            if (isPreview) {
                setLoadingDocument(true);
            }

            const requestBody = {
                sID: user.sID,
                items: itemsToDownload.map(i => ({
                    id: i.id,
                    type: 'fileCount' in i || 'isSystemFolder' in i ? 'folder' : 'file',
                    path: i.id // ID stores the full GS path usually
                }))
            };

            const response = await fetch("/api/uploadDocuments/download", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(requestBody),
            });

            if (!response.ok) {
                const errorData = await response.json();
                showNotification(errorData.message || (isPreview ? "Failed to open document" : "Failed to initiate download"), { severity: "error" });
                setLoadingDocument(false);
                return;
            }

            // Handle direct file stream or ZIP stream
            const contentType = response.headers.get("Content-Type");

            if (contentType && contentType.includes("application/json")) {
                const data = await response.json();
                if (data.url && data.singleFile) {
                    if (isPreview) {
                        try {
                            const firstItem = itemsToDownload[0];
                            const fileExt = firstItem.name.split('.').pop()?.toLowerCase();
                            const isTextBased = ['txt', 'md', 'csv', 'json', 'log'].includes(fileExt || '');
                            const isViewable = ['pdf', 'png', 'jpg', 'jpeg', 'gif', 'svg'].includes(fileExt || '');

                            if (isTextBased) {
                                // Fetch content directly from signed URL to show in Markdown Viewer
                                const contentResponse = await fetch(data.url);
                                const text = await contentResponse.text();
                                setReviewDocumentItem(itemsToDownload[0] as IFolderFile);
                                setDocumentContent(text);
                                setReadMode(true);
                                setLoadingDocument(false);
                            } else if (isViewable) {
                                // For PDFs / Images use the iframe preview renderer
                                setReviewDocumentItem(itemsToDownload[0] as IFolderFile);
                                setDocumentContent(data.url);
                                setReadMode(true);
                                setLoadingDocument(false);
                            } else {
                                // Fall back to opening a new tab for unknown file types
                                window.open(data.url, "_blank");
                                setLoadingDocument(false);
                                showNotification(`Opened ${displayName}`, { severity: "success" });
                            }
                        } catch (err) {
                            showNotification("Error loading document content", { severity: "error" });
                            setLoadingDocument(false);
                        }
                    } else {
                        const a = document.createElement("a");
                        a.href = data.url;
                        a.target = "_blank";
                        a.download = displayName;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        showNotification(`Downloaded ${displayName}`, { severity: "success" });
                    }
                } else {
                    showNotification(data.message || "Failed to initiate download", { severity: "error" });
                    setLoadingDocument(false);
                }
            } else if (contentType && !contentType.includes("application/json")) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;

                // Get filename from Content-Disposition header if available
                const contentDisposition = response.headers.get("Content-Disposition");
                let filename = isBulk ? `download_${new Date().getTime()}.zip` : itemsToDownload[0].name;
                if (contentDisposition && contentDisposition.includes('filename="')) {
                    filename = contentDisposition.split('filename="')[1].split('"')[0];
                } else if (contentType.includes("application/zip")) {
                    filename = isBulk ? `bulk_${new Date().getTime()}.zip` : `${itemsToDownload[0].name}.zip`;
                }

                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);
                showNotification(`Downloaded ${displayName}`, { severity: "success" });
            } else {
                showNotification("Failed to process download response", { severity: "error" });
            }

        } catch (error: any) {
            logger.error(`Error downloading: ${error?.message || error}`);
            showNotification(`Error downloading: ${error?.message || "Error connecting to download service"}`, { severity: "error" });
        }
    };

    const handleGoBack = () => {
        setReadMode(false);
        setReviewDocumentItem(null);
        setDocumentContent("");
    };

    return (
        <Box
            sx={{
                flex: 1,
                display: "flex",
                flexDirection: "column",
                height: "100%",
                overflow: "hidden",
            }}
        >
            {/* Header / Back Button when in Read Mode */}
            {readMode && (
                <Grid container rowSpacing={2} gap={1} mb={2}>
                    <Grid className="flex-row align-middle">
                        <Button
                            variant="outlined"
                            size="small"
                            startIcon={<ArrowBack />}
                            onClick={handleGoBack}
                        >
                            Back
                        </Button>
                    </Grid>
                    <Grid className="flex-row justify-evenly">
                        <Typography className="text-base" sx={{ flexGrow: 1, alignSelf: 'center', ml: 2 }}>
                            {loadingDocument ? "loading..." : reviewDocumentItem?.name}
                        </Typography>
                    </Grid>
                </Grid>
            )}

            {/* Folder Structure or Document Viewer */}
            <Box sx={{ flex: 1, overflow: "hidden", position: "relative" }}>
                {readMode ? (
                    <Box sx={{ height: "100%", width: "100%", overflowY: "auto", p: 2, bgcolor: "grey.50", borderRadius: 1 }}>
                        {loadingDocument ? (
                            <Typography>Loading document content...</Typography>
                        ) : documentContent.startsWith("http") ? (
                            <iframe
                                src={documentContent}
                                style={{ width: '100%', height: '100%', border: 'none' }}
                                title="Document Preview"
                            />
                        ) : (
                            <div className="markdown-container" suppressHydrationWarning={true}>
                                <MarkdownRenderer content={documentContent} />
                            </div>
                        )}
                    </Box>
                ) : (
                    <FolderStructure
                        files={mappedFiles}
                        initialSelectedIds={persistedSelectedIds}
                        onNavigateToPersonal={triggerNavigateToPersonal ? () => {
                            if (onNavigateComplete) onNavigateComplete();
                        } : undefined}
                        onFileSelect={(file) => {
                            handleGcsFileSelection([file.id]);
                            setSelectedFolderItems([file]);
                        }}
                        onFileOpen={(file) => {
                            handleDownload(file, true);
                        }}
                        onDownload={(item) => handleDownload(item)}
                        onDelete={() => {
                            handleGcsFileSelection([]);
                            setSelectedFolderItems([]);
                            setPersistedSelectedIds([]);
                            getCustomSourceDocuments(); // Let parent sync externalFiles if mutated
                        }}
                        onDataChange={() => {
                            getCustomSourceDocuments();
                        }}
                        onSelectionChange={(ids, items, resolvedFiles) => {
                            // Persist selection for remounts
                            setPersistedSelectedIds(ids);

                            const resolvedPaths = resolvedFiles.map(f => f.id);
                            handleGcsFileSelection(resolvedPaths, resolvedFiles);
                            setSelectedFolderItems(items);
                        }}
                    />
                )}
            </Box>
        </Box>
    );
};

export default CustomDocumentRenderer;
