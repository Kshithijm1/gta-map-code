import { NextRequest, NextResponse } from "next/server";
import { Storage } from "@google-cloud/storage";
import { SECRET_GCS_FILE_UPLOAD_BUCKET, SECRET_PROJECT_ID } from "@/lib/env";
import logger from "@/lib/logger";

/**
 * POST /api/uploadDocuments/shareToTeam
 * Copies files AND folders from personal to a team subfolder.
 *
 * Body: { sID, teamCode, files: string[], folders: string[], targetFolder }
 *   - files: gs:// URIs or relative paths of single files
 *   - folders: gs:// URIs or relative paths of folder prefixes (ending in /)
 *   - targetFolder: full GCS path prefix of the target team subfolder
 */

/** Strip gs:// prefix and bucket name, returning a clean relative GCS path */
const toRelative = (p: string): string => {
    if (p.startsWith("gs://")) {
        const parts = p.replace("gs://", "").split("/");
        parts.shift(); // remove bucket name
        return parts.join("/");
    }
    return p;
};

/** Collapse any double (or more) slashes into single slashes */
const cleanPath = (p: string): string => p.replace(/\/\/+/g, "/");

export async function POST(req: NextRequest) {
    try {
        const body = await req.json();
        const { sID, teamCode, files = [], folders = [], targetFolder } = body;

        if (!sID || !teamCode || !targetFolder) {
            return NextResponse.json(
                { success: false, message: "sID, teamCode, and targetFolder are required" },
                { status: 400 }
            );
        }

        logger.info(`[ShareToTeam] Request: sID="${sID}", teamCode="${teamCode}", files=${JSON.stringify(files)}, folders=${JSON.stringify(folders)}, targetFolder="${targetFolder}"`);

        const storage = new Storage({ projectId: SECRET_PROJECT_ID });
        const bucket = storage.bucket(SECRET_GCS_FILE_UPLOAD_BUCKET);

        // Normalize target prefix — ensure single trailing slash, no double slashes
        let targetPrefix = toRelative(targetFolder);
        if (!targetPrefix.endsWith("/")) targetPrefix += "/";
        targetPrefix = cleanPath(targetPrefix);

        logger.info(`[ShareToTeam] Resolved targetPrefix="${targetPrefix}"`);

        // Helper: copy a single file to the target prefix and tag with creatorSID
        const copyFile = async (relativePath: string, destPath: string): Promise<boolean> => {
            const cleanDest = cleanPath(destPath);
            const cleanSrc = cleanPath(relativePath);
            logger.info(`[ShareToTeam] Attempting copy: "${cleanSrc}" -> "${cleanDest}"`);
            try {
                await bucket.file(cleanSrc).copy(bucket.file(cleanDest));
                try {
                    await bucket.file(cleanDest).setMetadata({
                        metadata: {
                            creatorSID: String(sID)
                        }
                    });
                } catch (metaErr: any) {
                    logger.error(`[ShareToTeam] Metadata error on ${cleanDest}: ${metaErr?.message}`);
                }
                logger.info(`[ShareToTeam] ✓ Copied ${cleanSrc} -> ${cleanDest}`);
                return true;
            } catch (err: any) {
                logger.error(`[ShareToTeam] ✗ Copy error "${cleanSrc}" -> "${cleanDest}": ${err?.message}`);
                return false;
            }
        };

        const results: boolean[] = [];

        // --- Process individual files ---
        for (const fileId of files) {
            if (!fileId) continue;
            const relativePath = toRelative(fileId);
            const fileName = relativePath.split("/").pop();
            if (!fileName) continue;
            const destPath = cleanPath(`${targetPrefix}${fileName}`);
            results.push(await copyFile(relativePath, destPath));
        }

        // --- Process folders (recursive) ---
        for (const folderId of folders) {
            if (!folderId) continue;
            let folderPrefix = toRelative(folderId);
            if (!folderPrefix.endsWith("/")) folderPrefix += "/";
            folderPrefix = cleanPath(folderPrefix);

            // The folder name is the last non-empty segment of its prefix
            const segments = folderPrefix.replace(/\/$/, "").split("/");
            const folderName = segments[segments.length - 1];
            const destFolderPrefix = cleanPath(`${targetPrefix}${folderName}/`);

            logger.info(`[ShareToTeam] Processing folder: prefix="${folderPrefix}", folderName="${folderName}", destPrefix="${destFolderPrefix}"`);

            try {
                // Create destination folder marker with creatorSID
                await bucket.file(destFolderPrefix).save("", {
                    metadata: { contentType: "application/x-directory", metadata: { creatorSID: sID } }
                });

                // List and copy all objects under the source folder prefix
                const [nestedFiles] = await bucket.getFiles({ prefix: folderPrefix });
                logger.info(`[ShareToTeam] Found ${nestedFiles.length} objects under "${folderPrefix}"`);

                for (const f of nestedFiles) {
                    if (f.name.endsWith("/")) continue; // skip folder markers
                    const tail = f.name.substring(folderPrefix.length);
                    if (!tail) continue; // skip empty tails
                    const destPath = cleanPath(`${destFolderPrefix}${tail}`);
                    results.push(await copyFile(f.name, destPath));
                }
                logger.info(`[ShareToTeam] Shared folder ${folderPrefix} -> ${destFolderPrefix}`);
            } catch (err: any) {
                logger.error(`[ShareToTeam] Folder error ${folderId}: ${err?.message}`);
                results.push(false);
            }
        }

        const successCount = results.filter(Boolean).length;
        const totalCount = results.length;

        logger.info(`[ShareToTeam] Done: ${successCount}/${totalCount} items copied successfully`);

        return NextResponse.json({
            success: successCount > 0,
            message: `Shared ${successCount}/${totalCount} item(s)`,
            copiedCount: successCount,
        }, { status: 200 });

    } catch (error: unknown) {
        logger.error(`[ShareToTeam] Internal Error: ${error}`);
        return NextResponse.json(
            { success: false, message: "Internal server error" },
            { status: 500 }
        );
    }
}
