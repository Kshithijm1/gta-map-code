    // Derive implicit folders from file paths — ensures nested folders appear
    // even when explicit folder marker objects are missing (e.g. from older shares)
    const existingFolderPaths = new Set(folderData.map(f => f.gcsPrefix));
    const implicitFolders: typeof folderData = [];

    for (const file of filteredFiles) {
      const segments = file.name.split("/");
      // segments: [sID, folder1, folder2, ..., filename]
      // We need intermediate folders: sID/folder1/, sID/folder1/folder2/, etc.
      // Skip the first segment (sID root) and last segment (filename)
      for (let i = 2; i < segments.length; i++) {
        const folderGcsPath = segments.slice(0, i).join("/") + "/";
        if (folderGcsPath === `${sID}/`) continue; // skip the root prefix
        if (existingFolderPaths.has(folderGcsPath)) continue; // already known
        existingFolderPaths.add(folderGcsPath);
        const folderName = segments[i - 1];
        implicitFolders.push({
          id: `gs://${bucket}/${folderGcsPath}`,
          name: folderName,
          path: `gs://${bucket}/${folderGcsPath}`,
          gcsPrefix: folderGcsPath,
          creatorSID: null,
          createdAt: null,
        });
      }
    }

    if (implicitFolders.length > 0) {
      logger.info(`[FetchGcsFiles] Discovered ${implicitFolders.length} implicit folder(s) from file paths: ${implicitFolders.map(f => f.gcsPrefix).join(", ")}`);
    }

    const allFolders = [...folderData, ...implicitFolders];

    return Response.json(
      {
        success: true,
        count: fileData.length,
        files: fileData,
        folders: allFolders,
      },
      { status: 200, statusText: "Successfully fetched files" }
    );
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
  } catch (error: any) {
    logger.error(`Error fetching files ${error}`);
    return Response.json(
      {
        success: false,
        count: 0,
        files: [],
      },
      { status: 500, statusText: "Error in the API" }
    );
  }
};
